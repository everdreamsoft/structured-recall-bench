# ─────────────────────────────────────────────────────────────────────
# Structured Recall Bench — environment configuration
#
# Copy this file to `.env` and fill in the keys for the providers you
# want to run. All keys are OPTIONAL individually:
#   • OPENAI_API_KEY   → required for answer generation (all providers)
#   • Provider keys    → required only if you run that specific provider
#
# NEVER commit `.env`. It is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────

# ─── Answer generation (required for non-dry-run) ────────────────────
# Used by src/utils/llm.ts to generate the final answer given the
# provider's retrieved context. Default model: gpt-4o-mini.
# Get it at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: override the answer-generation model.
# Examples: gpt-4o-mini, gpt-4.1, gpt-4.1-mini
# Default: gpt-4o-mini
# SRB_ANSWER_MODEL=gpt-4o-mini

# ─── Mem0 (cloud, managed) ───────────────────────────────────────────
# Free tier: ~10k memories/month. No credit card required to start.
# Sign up at https://app.mem0.ai → Settings → API Keys
# Leave empty if you don't plan to run the `mem0` provider.
MEM0_API_KEY=

# ─── Zep (cloud, managed) ────────────────────────────────────────────
# Free tier available. Sign up at https://www.getzep.com
# → Dashboard → API Keys
ZEP_API_KEY=

# ─── Supermemory (cloud, managed) ────────────────────────────────────
# Free tier available. Sign up at https://supermemory.ai
# → Settings → API Keys
SUPERMEMORY_API_KEY=
# Optional override (defaults to https://api.supermemory.ai)
# SUPERMEMORY_BASE_URL=

# ─── Sandra (EverDreamSoft semantic graph, self-hosted) ──────────────
# Sandra runs as a local MCP server. Default URL is the memorybench
# test instance on :8091. Use :8090 for the production sandbox server.
# SANDRA_URL=http://localhost:8091/mcp
# SANDRA_URL=http://localhost:8090/mcp

# Bearer token for Sandra's OAuth-protected MCP endpoint. Issued per
# user by the Sandra server; leave empty if running an unauthenticated
# local dev server.
# SANDRA_TOKEN=

# Sandra's ingestion pipeline extracts entities and facts from each
# session using an LLM. The default extractor is Claude — provide
# ANTHROPIC_API_KEY below, or point SANDRA_EXTRACTOR_MODEL at an OpenAI
# model and use OPENAI_API_KEY instead.
# SANDRA_EXTRACTOR_MODEL=claude-sonnet-4-6
# SANDRA_EXTRACTOR_MODEL=gpt-4o-mini

# Skip Sandra's automatic embedding pass during ingestion (faster, but
# downgrades semantic_search quality). Set to 1 for CI/smoke tests.
# SANDRA_SKIP_AUTO_EMBED=0

# ─── Anthropic (used by Sandra extractor by default) ─────────────────
# Only needed if SANDRA_EXTRACTOR_MODEL is a Claude model (default).
# Get it at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── Google (optional — only if you add a Gemini-backed provider) ────
# Not currently used by SRB. Reserved for cross-model comparison runs.
# GOOGLE_API_KEY=
