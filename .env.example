# ─────────────────────────────────────────────────────────────────────
# Structured Recall Bench — environment configuration
#
# Copy this file to `.env` and fill in the keys for the providers you
# want to run. All keys are OPTIONAL individually:
#   • OPENAI_API_KEY   → required for answer generation (all providers)
#   • Provider keys    → required only if you run that specific provider
#
# NEVER commit `.env`. It is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────

# ─── Answer generation (required for non-dry-run) ────────────────────
# Used by src/utils/llm.ts to generate the final answer given the
# provider's retrieved context. Default model: gpt-4o-mini.
# Get it at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: override the answer-generation model.
# Examples: gpt-4o-mini, gpt-4.1, gpt-4.1-mini
# Default: gpt-4.1-mini (better on long structured context than gpt-4o-mini)
# SRB_ANSWER_MODEL=gpt-4.1-mini

# ─── Mem0 (cloud, managed) ───────────────────────────────────────────
# Free tier: ~10k memories/month. No credit card required to start.
# Sign up at https://app.mem0.ai → Settings → API Keys
# Leave empty if you don't plan to run the `mem0` provider.
MEM0_API_KEY=

# ─── Zep (cloud, managed) ────────────────────────────────────────────
# Free tier available. Sign up at https://www.getzep.com
# → Dashboard → API Keys
ZEP_API_KEY=

# ─── Supermemory (cloud, managed) ────────────────────────────────────
# Free tier available. Sign up at https://supermemory.ai
# → Settings → API Keys
SUPERMEMORY_API_KEY=
# Optional override (defaults to https://api.supermemory.ai)
# SUPERMEMORY_BASE_URL=

# ─── Sandra (required for the `sandra-structured` provider) ──────────
# Sandra runs as an MCP server. The built-in `sandra-structured` provider
# reads these two vars only; it does NOT use an extractor LLM at query
# time (the graph is populated from the SRB dataset at ingestion).
# SANDRA_URL=http://localhost:8091/mcp
# SANDRA_TOKEN=
